{
  "profile_name": "cuquantum-ideal-depth-sweep-wsl",
  "execution_env": "wsl2_ubuntu_gpu_cuquantum_ideal_depth",
  "preliminary": false,
  "results_dir": "results/cuquantum-ideal-depth-sweep-wsl",
  "max_reference_qubits": 12,
  "defaults": {
    "warmups": 2,
    "repeats": 5,
    "thread_modes": ["all"],
    "execution_mode": "persistent_group",
    "executor": "wsl_python",
    "output_qubits": [0, 1, 2, 3, 4, 5, 6, 7],
    "shots": 4096,
    "noise_profile": "none",
    "timeouts": {"case_s": 600},
    "memory_limits": {
      "ram_fraction": 0.75,
      "vram_fraction": 0.80,
      "overhead_factor": 1.5
    }
  },
  "benchmarks": [
    {
      "variant": "cpu_statevector",
      "library": "qiskit_aer",
      "backend": "aer_statevector",
      "sim_method": "statevector",
      "output_mode": "statevector",
      "backend_options": {"method": "statevector"},
      "devices": ["CPU"],
      "precisions": ["double"],
      "families": ["ansatz", "random", "trotter"],
      "qubit_grid": {"ansatz": [8, 10, 12], "random": [8, 10, 12], "trotter": [8, 10, 12]},
      "depths": {"ansatz": [2, 4, 8, 12, 16, 24, 32], "random": [2, 4, 8, 12, 16, 24, 32], "trotter": [2, 4, 8, 12, 16, 24, 32]},
      "seeds": {"default": [101, 202]}
    },
    {
      "variant": "gpu_thrust",
      "library": "qiskit_aer",
      "backend": "aer_statevector",
      "sim_method": "statevector",
      "output_mode": "marginal_probabilities",
      "backend_options": {"method": "statevector", "cuStateVec_enable": false},
      "devices": ["GPU"],
      "precisions": ["double"],
      "families": ["ansatz", "random", "trotter"],
      "qubit_grid": {"ansatz": [16, 20, 24, 28], "random": [16, 20, 24, 28], "trotter": [16, 20, 24, 28]},
      "depths": {"ansatz": [2, 4, 8, 12, 16, 24, 32], "random": [2, 4, 8, 12, 16, 24, 32], "trotter": [2, 4, 8, 12, 16, 24, 32]},
      "seeds": {"default": [101, 202]}
    },
    {
      "variant": "gpu_tensornetwork",
      "library": "qiskit_aer",
      "backend": "aer_tensor_network",
      "sim_method": "tensor_network",
      "output_mode": "marginal_probabilities",
      "backend_options": {"method": "tensor_network", "use_cuTensorNet_autotuning": true},
      "devices": ["GPU"],
      "precisions": ["double"],
      "families": ["ansatz", "random", "trotter"],
      "qubit_grid": {"ansatz": [16, 20, 24, 28], "random": [16, 20, 24, 28], "trotter": [16, 20, 24, 28]},
      "depths": {"ansatz": [2, 4, 8, 12, 16, 24, 32], "random": [2, 4, 8, 12, 16, 24, 32], "trotter": [2, 4, 8, 12, 16, 24, 32]},
      "seeds": {"default": [101, 202]}
    }
  ]
}
