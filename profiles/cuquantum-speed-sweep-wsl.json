{
  "profile_name": "cuquantum-speed-sweep-wsl",
  "execution_env": "wsl2_ubuntu_gpu_cuquantum_speed",
  "preliminary": false,
  "results_dir": "results/cuquantum-speed-sweep-wsl",
  "max_reference_qubits": 12,
  "defaults": {
    "warmups": 2,
    "repeats": 5,
    "thread_modes": ["all"],
    "timeouts": {
      "case_s": 900
    },
    "memory_limits": {
      "ram_fraction": 0.75,
      "vram_fraction": 0.80,
      "overhead_factor": 1.5
    },
    "execution_mode": "persistent_group",
    "output_mode": "statevector",
    "noise_profile": "none"
  },
  "benchmarks": [
    {
      "variant": "cpu_statevector",
      "library": "qiskit_aer",
      "backend": "aer_statevector",
      "sim_method": "statevector",
      "backend_options": {
        "method": "statevector"
      },
      "devices": ["CPU"],
      "precisions": ["double"],
      "families": ["ghz", "random", "ansatz", "trotter"],
      "qubit_grid": {
        "ghz": [20, 22, 24, 26, 28],
        "random": [20, 22, 24, 26, 28],
        "ansatz": [20, 22, 24, 26, 28],
        "trotter": [20, 22, 24, 26, 28]
      },
      "depths": {
        "random": 8,
        "ansatz": 6,
        "trotter": 12
      },
      "memory_limits": {
        "ram_source": "total"
      },
      "seeds": {
        "ghz": [101],
        "default": [101, 202]
      }
    },
    {
      "variant": "gpu_thrust",
      "library": "qiskit_aer",
      "backend": "aer_statevector",
      "sim_method": "statevector",
      "backend_options": {
        "method": "statevector",
        "cuStateVec_enable": false
      },
      "devices": ["GPU"],
      "precisions": ["double"],
      "families": ["ghz", "random", "ansatz", "trotter"],
      "qubit_grid": {
        "ghz": [20, 22, 24, 26, 28],
        "random": [20, 22, 24, 26, 28],
        "ansatz": [20, 22, 24, 26, 28],
        "trotter": [20, 22, 24, 26, 28]
      },
      "depths": {
        "random": 8,
        "ansatz": 6,
        "trotter": 12
      },
      "seeds": {
        "ghz": [101],
        "default": [101, 202]
      }
    },
    {
      "variant": "gpu_custatevec",
      "library": "qiskit_aer",
      "backend": "aer_statevector",
      "sim_method": "statevector",
      "backend_options": {
        "method": "statevector",
        "cuStateVec_enable": true
      },
      "devices": ["GPU"],
      "precisions": ["double"],
      "families": ["ghz", "random", "ansatz", "trotter"],
      "qubit_grid": {
        "ghz": [20, 22, 24, 26, 28],
        "random": [20, 22, 24, 26, 28],
        "ansatz": [20, 22, 24, 26, 28],
        "trotter": [20, 22, 24, 26, 28]
      },
      "depths": {
        "random": 8,
        "ansatz": 6,
        "trotter": 12
      },
      "seeds": {
        "ghz": [101],
        "default": [101, 202]
      }
    }
  ]
}
